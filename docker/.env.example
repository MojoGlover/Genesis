# GENESIS Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys (External Services)
# =============================================================================

# OpenAI API (for GPT models)
OPENAI_API_KEY=sk-your-key-here

# Anthropic API (for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google API (if using Gemini)
GOOGLE_API_KEY=your-google-api-key

# Other API keys as needed
SERPAPI_KEY=
ELEVENLABS_API_KEY=


# =============================================================================
# Local Model Configuration (Ollama)
# =============================================================================

# Ollama base URL (host.docker.internal for Docker Desktop)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default models to use
OLLAMA_SMALL_MODEL=phi3:mini
OLLAMA_LARGE_MODEL=llama3.1:70b


# =============================================================================
# Vector Database (Qdrant)
# =============================================================================

# When running with docker-compose, use service name
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Collection settings
QDRANT_COLLECTION_NAME=genesis_memory


# =============================================================================
# Application Settings
# =============================================================================

# Environment (development/production)
GENESIS_ENV=development

# Gradio server settings
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/genesis.log


# =============================================================================
# Mission Configuration
# =============================================================================

# Path to mission file
MISSION_FILE=MISSION.md

# Agent behavior overrides (optional)
AGENT_NAME=
AGENT_ROLE=
AGENT_GOAL=


# =============================================================================
# Database Settings
# =============================================================================

# SQLite database path
DATABASE_PATH=data/conversations.db

# Backup settings
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=daily


# =============================================================================
# Security
# =============================================================================

# Session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=

# Enable authentication
AUTH_ENABLED=false
AUTH_USERNAME=
AUTH_PASSWORD=


# =============================================================================
# Performance
# =============================================================================

# Max conversation history to keep in memory
MAX_HISTORY_LENGTH=50

# Embedding batch size
EMBEDDING_BATCH_SIZE=100

# Request timeout (seconds)
REQUEST_TIMEOUT=300

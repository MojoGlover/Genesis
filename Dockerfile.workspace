FROM ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    python3.11 python3-pip git curl wget vim nano \
    build-essential nodejs npm \
    && rm -rf /var/lib/apt/lists/*
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1
RUN pip install --no-cache-dir pytest requests pandas numpy matplotlib jupyter
RUN mkdir -p /workspace/{projects,experiments,data,tools,tmp,output}
WORKDIR /workspace
CMD ["tail", "-f", "/dev/null"]
